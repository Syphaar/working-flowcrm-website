{
  "name": "flowcrm-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "seed": "tsx src/seed.ts",
    "test": "node --import tsx --test src/tests/*.test.ts",
    "test:auth": "node --import tsx --test src/tests/auth.test.ts",
    "test:users": "node --import tsx --test src/tests/users.test.ts",
    "test:leads": "node --import tsx --test src/tests/leads.test.ts",
    "test:deals": "node --import tsx --test src/tests/deals.test.ts",
    "test:tasks": "node --import tsx --test src/tests/tasks.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0-rc.2",
    "nodemailer": "^7.0.2",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^6.4.17",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
